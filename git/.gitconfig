# This is Git's per-user configuration file.
[core]
	editor = emacs
[user]
	name = Davis Vann Bennett
	email = davis.v.bennett@gmail.com
	username = d-v-b
[github]
	user = d-v-b
[filter "lfs"]
	smudge = git-lfs smudge %f
	required = true
	clean = git-lfs clean %f
[push]
	default = current
	followTags = true
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper = 
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
# Machine-local, untracked config: credentials, tokens, platform overrides.
# NEVER put secrets in this tracked file — the repo is public.
[include]
	path = ~/.gitconfig.local
